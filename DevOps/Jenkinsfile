pipeline {
    agent any
    environment {
        DOCKER_HUB_USERNAME = credentials('DOCKER_USERNAME') // GitHub/Docker Hub username
        DOCKER_HUB_PASSWORD = credentials('DOCKER_PASSWORD') // Docker Hub password
        SERVER_HOST = credentials('SERVER_HOST')
        SERVER_USER = credentials('SERVER_USER')
        SERVER_SSH_KEY = credentials('SERVER_SSH_KEY')
    }

    stages {
        stage('Build, Test, Docker & Deploy All Services') {
            parallel {
                // Define all services
                stage('Microservices Loop') {
                    steps {
                        script {
                            def services = [
                                'FarmersMK-auth-service',
                                'FarmersMK-user-service',
                                'FarmersMK-mastercard-service',
                                'FarmersMK-socialmediafacebook-service',
                                'FarmersMK-socialmediatwitter-service',
                                'FarmersMK-socialmediainstagram-service',
                                'FarmersMK-socialmedialinkedin-service',
                                'FarmersMK-payments-service',
                                'FarmersMK-notification-service',
                                'FarmersMK-inventory-service',
                                'FarmersMK-orders-service',
                                'FarmersMK-shipping-service',
                                'FarmersMK-reports-service',
                                'FarmersMK-analytics-service',
                                'FarmersMK-customer-service',
                                'FarmersMK-support-service',
                                'FarmersMK-settings-service',
                                'FarmersMK-security-service',
                                'FarmersMK-search-service',
                                'FarmersMK-recommendation-service',
                                'FarmersMK-logging-service'
                            ]

                            def stagesMap = [:]

                            services.each { service ->
                                stagesMap[service] = {
                                    node {
                                        stage("Build & Test: ${service}") {
                                            dir("services/${service}") {
                                                sh 'mvn clean package -B'
                                                sh 'mvn test'
                                            }
                                        }

                                        stage("Docker Build & Push: ${service}") {
                                            dir("services/${service}") {
                                                sh """
                                                echo $DOCKER_HUB_PASSWORD | docker login -u $DOCKER_HUB_USERNAME --password-stdin
                                                docker build -t $DOCKER_HUB_USERNAME/${service}:latest .
                                                docker push $DOCKER_HUB_USERNAME/${service}:latest
                                                """
                                            }
                                        }

                                        stage("Deploy: ${service}") {
                                            sh """
                                            ssh -o StrictHostKeyChecking=no -i $SERVER_SSH_KEY $SERVER_USER@$SERVER_HOST '
                                                docker pull $DOCKER_HUB_USERNAME/${service}:latest
                                                docker stop ${service} || true
                                                docker rm ${service} || true
                                                docker run -d --name ${service} -p 8080:8080 $DOCKER_HUB_USERNAME/${service}:latest
                                            '
                                            """
                                        }
                                    }
                                }
                            }

                            parallel stagesMap
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            echo "Pipeline completed."
        }
        success {
            echo "All services built, tested, dockerized and deployed successfully!"
        }
        failure {
            echo "Pipeline failed. Check logs for errors."
        }
    }
}